# Minimal env example for local development
# Required for the app to be "configured" (see src/lib/env.ts)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# R2 (Cloudflare) optional
CF_R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_PUBLIC=classifly-media-dev
R2_BUCKET_PRIVATE=classifly-private-dev
NEXT_PUBLIC_R2_PUBLIC_URL=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
