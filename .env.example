# =====================================================================
# Classifly.in — Local development environment variables
# =====================================================================
# Copy to .env.local and fill in your actual values.
# See SETUP.md for how to obtain each value.

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here-NEVER-COMMIT

# ---------- Cloudflare R2 (object storage) ----------
CF_R2_ACCOUNT_ID=your-cf-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET_PUBLIC=classifly-media-dev
R2_BUCKET_PRIVATE=classifly-private-dev
NEXT_PUBLIC_R2_PUBLIC_URL=https://media-dev.classifly.in

# ---------- Razorpay (payments) ----------
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your-secret-here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ---------- MSG91 (SMS OTP fallback; Supabase handles primary) ----------
MSG91_AUTH_KEY=your-msg91-key
MSG91_SENDER_ID=CLSFLY
MSG91_OTP_TEMPLATE_ID=your-dlt-template-id

# ---------- Resend (transactional email) ----------
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=hello@classifly.in

# ---------- Surepass (KYC verification, pay-per-use) ----------
SUREPASS_API_TOKEN=your-token

# ---------- Upstash Redis (rate limiting + cache) ----------
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ---------- Observability ----------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
AXIOM_DATASET=classifly-dev
AXIOM_TOKEN=

# ---------- App config ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
